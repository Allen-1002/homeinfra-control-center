# Container listen address inside Docker. Keep 0.0.0.0 so the container can
# accept traffic from the Compose bridge; this does not publish the service to
# your LAN or the Internet by itself.
APP_HOST=0.0.0.0
# Host-side bind address for published ports. Keep 127.0.0.1 unless you
# intentionally want to expose the UI beyond this machine.
HOST_BIND=127.0.0.1
HOST_PORT=8010
APP_PORT=8000
LOG_LEVEL=INFO
STORE_MODE=sqlite
HOMEINFRA_DB_PATH=/app/data/homeinfra.db

# Collector mode: ssh (real collection), disabled (no collection)
COLLECTOR_MODE=disabled

# SSH settings (used when COLLECTOR_MODE=ssh)
SSH_CONNECT_TIMEOUT=10
SSH_AUTO_ACCEPT_HOST_KEY=0
SSH_RETRY_MAX=3
SSH_RETRY_BASE_DELAY=1.0
# SSH_KNOWN_HOSTS=/app/ssh/known_hosts
